# ─── PostgreSQL ──────────────────────
DB_USER=schooladmin
DB_PASSWORD=schoolpass2026
# Dev: connect directly. Prod (api/worker): set DB_HOST=pgbouncer via docker-stack.yml.
DATABASE_URL=postgresql://schooladmin:schoolpass2026@localhost:5432/school_access

# ─── PgBouncer ───────────────────────
# Set to "true" only for api/worker containers that route through PgBouncer.
# The migrator container must NOT set this — it connects directly to postgres:5432
# because prisma migrate deploy is incompatible with PgBouncer transaction mode.
# In docker-stack.yml these are already configured per-service.
PGBOUNCER_ENABLED=false

# ─── Redis ───────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Object Storage (Hetzner S3) ─────────────
# The MinIO SDK is used as an S3-compatible client; no MinIO server is needed.
HETZNER_ENDPOINT=fsn1.your-objectstorage.com
HETZNER_PORT=443
HETZNER_SSL=true
HETZNER_ACCESS_KEY=your-access-key
HETZNER_SECRET_KEY=your-secret-key

# Bucket names (defaults shown — override if needed)
# HETZNER_HISTORY_BUCKET=iacloud-school-history-records
# MINIO_STUDENT_PHOTOS_BUCKET=student-photos
# MINIO_EVENT_PHOTOS_BUCKET=event-photos

# Auto-expiration for event photos in days (0 = disabled)
# STORAGE_HISTORY_RETENTION_DAYS=90

# ─── JWT Auth ────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string-64chars
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string

# ─── n8n ─────────────────────────────
N8N_USER=admin
N8N_PASSWORD=n8npass2026
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ─── Domain (for Caddy + n8n) ────────
DOMAIN=localhost

# ─── App ─────────────────────────────
PORT=4000
NODE_ENV=development

# AutoRegister CGI cloud-only
AUTOREG_INTERNAL_TOKEN=change-me-autoreg-internal-token
AUTOREG_PUBLIC_BASE_URL=http://localhost:4000
