# Force LF line endings for all text files in the repository
# This ensures consistent line endings across Windows, macOS, and Linux
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.conf text eol=lf
*.sql text eol=lf
*.env text eol=lf
*.example text eol=lf
*.prisma text eol=lf
*.txt text eol=lf
Dockerfile text eol=lf
Caddyfile text eol=lf

# Binary files - never modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.gz binary
*.tar binary
