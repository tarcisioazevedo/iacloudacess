{
  "name": "school-access-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:api\"",
    "dev:frontend": "vite --port 3000 --host 0.0.0.0",
    "dev:api": "tsx watch api/server.ts",
    "dev:edge": "tsx watch edge-agent/main.ts run",
    "build": "vite build",
    "preview": "vite preview",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "edge:run": "tsx edge-agent/main.ts run",
    "edge:claim": "tsx edge-agent/main.ts claim",
    "edge:simulate-event": "tsx edge-agent/main.ts simulate-event",
    "edge:doctor": "tsx edge-agent/main.ts doctor",
    "build:edge-win": "node scripts/build-edge-win.cjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:whatsapp": "tsx api/tests/whatsappReliabilityTest.ts",
    "test:whatsapp:live": "DRY_RUN=false tsx api/tests/whatsappReliabilityTest.ts",
    "compose:dev": "docker compose -f docker-stack.yml -f docker-compose.dev.yml up -d --build",
    "compose:dev:down": "docker compose -f docker-stack.yml -f docker-compose.dev.yml down",
    "compose:dev:logs": "docker compose -f docker-stack.yml -f docker-compose.dev.yml logs -f api",
    "swarm:dev": "npm run compose:dev",
    "swarm:dev:down": "npm run compose:dev:down",
    "swarm:dev:logs": "npm run compose:dev:logs",
    "docker:build": "docker build -t school-access-api:latest -f Dockerfile . && docker build -t school-access-frontend:latest -f Dockerfile.frontend .",
    "swarm:deploy": "bash scripts/deploy-swarm.sh",
    "swarm:status": "docker stack services school",
    "swarm:logs": "docker service logs school_api -f --tail 100"
  },
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@prisma/client": "^6.9.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.40.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "md5": "^2.3.0",
    "minio": "^8.0.7",
    "motion": "^12.23.0",
    "multer": "^2.1.0",
    "nodemailer": "^6.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.13.0",
    "sharp": "^0.33.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.0",
    "@types/nodemailer": "^6.4.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  }
}
